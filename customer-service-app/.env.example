# WebSocket配置
REACT_APP_WS_URL=ws://localhost:6006/ws
REACT_APP_WS_SECURE_URL=wss://api.example.com/ws

# API配置
REACT_APP_API_URL=http://localhost:6006/api
REACT_APP_API_TIMEOUT=10000

# 安全配置
REACT_APP_ENCRYPTION_KEY=your-encryption-key-here
REACT_APP_CSRF_TOKEN_HEADER=X-CSRF-Token

# 监控配置
REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
REACT_APP_GA_TRACKING_ID=UA-XXXXXXXXX-X

# 功能开关
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_PERFORMANCE_MONITOR=true
REACT_APP_ENABLE_ERROR_REPORTING=true

# 构建配置
REACT_APP_VERSION=$npm_package_version
REACT_APP_BUILD_TIME=$BUILD_TIME