{
  "name": "customer-service-app",
  "version": "1.0.0",
  "description": "Enterprise-grade customer service application with WebSocket support",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "fix:console": "node scripts/fix-console-logs.js",
    "security:check": "npm audit",
    "build:prod": "npm run lint && npm run test -- --watchAll=false && npm run build"
  },
  "dependencies": {
    "@sentry/react": "^9.40.0",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.2.6",
    "eventemitter3": "^5.0.1",
    "helmet": "^8.1.0",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "lz-string": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-window": "^1.8.10",
    "react-window-infinite-loader": "^1.0.9",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.6.2",
    "source-map-explorer": "^2.5.3"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
